{
  "tasks": {
    "dev": "deno run --unstable-kv --allow-net --allow-env --watch main.ts",
    "start": "deno run --unstable-kv --allow-net --allow-env main.ts",
    "check": "deno check main.ts",
    "fmt": "deno fmt main.ts",
    "lint": "deno lint main.ts"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window", "deno.unstable"]
  }
}
