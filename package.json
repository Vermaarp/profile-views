{
  "name": "profile-views",
  "version": "1.0.0",
  "description": "Open-source GitHub profile view counter",
  "type": "module",
  "main": "api/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "lint": "eslint api/ badge/ --ext .js",
